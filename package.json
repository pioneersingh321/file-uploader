{
  "name": "@bolt/file-uploader",
  "version": "1.0.0",
  "description": "Capacitor plugin for FileUploader",
  "main": "dist/plugin.cjs.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/plugin.cjs.js"
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "android/",
    "dist/"
  ],
  "author": "",
  "license": "MIT",
  "keywords": [
    "capacitor",
    "plugin",
    "native",
    "ionic"
  ],
  "scripts": {
    "build": "npm run clean && tsc && rollup -c rollup.config.js",
    "clean": "rimraf ./dist",
    "watch": "tsc --watch",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "@capacitor/core": "^8.0.0",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "rimraf": "^6.0.1",
    "rollup": "^4.24.0",
    "typescript": "^5.6.3"
  },
  "peerDependencies": {
    "@capacitor/core": "^8.0.0"
  },
  "capacitor": {
    "android": {
      "src": "android"
    }
  }
}